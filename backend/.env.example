# Copy this file to .env and fill in your values. Never commit the real .env.

# Groq API key — https://console.groq.com/keys (free tier available)
GROQ_API_KEY=your_groq_api_key_here

# Groq model to use for governance reasoning
GROQ_MODEL=llama-3.3-70b-versatile

# Server port
PORT=5000

# Comma-separated list of allowed frontend origins (CORS)
CORS_ORIGIN=http://localhost:3000

# Number of top policy chunks to retrieve per query
RETRIEVAL_TOP_K=5

# Rebuild vector indexes from source .docx on every server start
# (set to "false" once indexes are built to speed up subsequent boots)
REBUILD_INDEX_ON_START=true
